# ============================================================
# TB Mulya Abadi Backend API - Environment Variables
# Salin file ini ke .env dan sesuaikan nilainya
# ============================================================

# Application
NODE_ENV=production
PORT=3000
APP_NAME="TB Mulya Abadi Backend API"
APP_URL=https://your-backend-url.railway.app
API_VERSION=v1

# Database (Railway MySQL — salin dari Railway dashboard)
DATABASE_URL="mysql://user:password@host:port/dbname"

# JWT (ganti dengan string random panjang, minimal 32 karakter)
JWT_ACCESS_SECRET=ganti-dengan-string-random-minimal-32-karakter
JWT_REFRESH_SECRET=ganti-dengan-string-random-lain-minimal-32-karakter
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Upload
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=image/jpeg,image/jpg,image/png,image/webp

# CORS (URL frontend Vercel)
CORS_ORIGIN=https://your-frontend.vercel.app,http://localhost:5173

# Logging
LOG_LEVEL=info

# Pagination
DEFAULT_PAGE=1
DEFAULT_LIMIT=10
MAX_LIMIT=100

# Google OAuth (dari Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://your-backend-url.railway.app/api/v1/auth/google/callback
FRONTEND_URL=https://your-frontend.vercel.app
